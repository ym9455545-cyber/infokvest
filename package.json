{
	"name": "small-ct",
	"version": "2.1.45",
	"title": "Blocksy",
	"browserslist": "> 1%, not opera > 0, not op_mini all",
	"devDependencies": {
		"babel-plugin-lodash": "3.3.4",
		"octokit": "5.0.5",
		"babel-jest": "29.7.0",
		"env-cmd": "10.1.0",
		"gulp-remove-code": "3.0.4",
		"jest": "29.7.0",
		"negotiator": "0.6.3",
		"openai": "6.3.0"
	},
	"scripts": {
		"dev": "gulp dev",
		"build": "cross-env NODE_ENV=production gulp build --silent",
		"gettext-generate": "gulp gettext-generate --silent",
		"changelogs": "env-cmd --silent node scripts/get-changelog.js",
		"set-version": "node scripts/set-version.js",
		"notify-nightly-done": "env-cmd --silent node scripts/notify-nightly-done.js",
		"make-release": "env-cmd --silent node scripts/make-release.js",
		"sync-google-fonts": "env-cmd --silent node scripts/sync-google-fonts.js",
		"test": "NODE_ENV=test jest",
		"create-issues-changelogs": "env-cmd --silent node scripts/create-issues-changelogs.js",
		"set-issue-data": "env-cmd --silent node scripts/set-issue-data.js",
		"make-theme-zip": "cross-env NODE_ENV=production gulp build_zips --silent && rm -rf build_tmp/blocksy && cp -R build_tmp/build build_tmp/blocksy"
	},
	"babel": {
		"env": {
			"test": {
				"plugins": ["@babel/plugin-transform-modules-commonjs"]
			}
		}
	},
	"dependencies": {
		"@creative-themes/build-process": "6.0.27",
		"@creative-themes/flexy": "1.0.3",
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/modifiers": "9.0.0",
		"@dnd-kit/sortable": "10.0.0",
		"@dnd-kit/utilities": "3.2.2",
		"@wordpress/components": "25.7.0",
		"@wordpress/date": "3.15.1",
		"@wordpress/i18n": "3.20.0",
		"@wordpress/icons": "6.3.0",
		"array-move": "2.2.2",
		"bezier-easing": "2.1.0",
		"body-scroll-lock": "3.1.5",
		"classnames": "2.3.2",
		"colord": "2.9.3",
		"cross-env": "7.0.3",
		"@creative-themes/wordpress-helpers": "1.0.2",
		"@creative-themes/customizer-sync-helpers": "3.0.4",
		"deep-equal": "1.1.1",
		"dom-chef": "3.6.3",
		"downshift": "9.0.10",
		"fast-deep-equal": "3.1.3",
		"gradient-parser": "1.0.2",
		"infinite-scroll": "5.0.0",
		"match-conditions": "1.0.17",
		"md5": "2.3.0",
		"nanoid": "5.1.6",
		"prettier": "3.6.2",
		"react-beautiful-dnd": "13.1.1",
		"react-copy-to-clipboard": "5.1.0",
		"react-router-dom": "6.30.3",
		"react-spring": "9.7.4",
		"react-window": "1.8.9",
		"remove-accents": "0.5.0",
		"scriptjs": "2.5.9",
		"simple-linear-scale": "1.0.1",
		"use-force-update": "1.0.11",
		"webfontloader": "1.6.28"
	}
}
